# Supabase — copia a .env.local y rellena con tus credenciales del proyecto.
# Dashboard Supabase → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://TU-PROYECTO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-anon-public-key

# Modo mantenimiento: "true" redirige el sitio público a /mantenimiento.
# El CRM (/crm, /login) sigue accesible. Déjalo vacío o en "false" para operación normal.
MAINTENANCE_MODE=false
